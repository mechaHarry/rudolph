{
  "manifest_version": 3,
  "name": "Rudolph",
  "version": "1.1.0",
  "description": "New tab dashboard with live Cisco stock price and competitor stock analysis.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [],
  "host_permissions": [
    "https://query1.finance.yahoo.com/*"
  ],
  "web_accessible_resources": [{
    "resources": ["wallpapers/*"],
    "matches": ["<all_urls>"]
  }]
}
