{
  "manifest_version": 3,
  "name": "Rudolph",
  "version": "1.0.2",
  "description": "Customizable new tab dashboard with live stock watchlists and market charts.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [],
  "host_permissions": [
    "https://query1.finance.yahoo.com/*"
  ],
  "web_accessible_resources": [{
    "resources": ["css/gridstack.min.css", "js/gridstack.min.js"],
    "matches": ["<all_urls>"]
  }]
}
